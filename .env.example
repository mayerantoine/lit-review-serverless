# ==============================================================================
# Literature Review Serverless - Environment Configuration Template
# ==============================================================================
#
# INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Replace all placeholder values with your actual credentials
# 3. Never commit .env file to version control (it's in .gitignore)
#
# ==============================================================================

# ------------------------------------------------------------------------------
# OpenAI API Configuration
# ------------------------------------------------------------------------------
# Get your API key from: https://platform.openai.com/api-keys
# Required for: Embeddings, relevance scoring, and text generation
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_API_KEY_HERE

# ------------------------------------------------------------------------------
# Frontend Configuration
# ------------------------------------------------------------------------------
# URL where the FastAPI backend is running
# Development: http://localhost:8000
# Production: https://your-api-domain.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# ------------------------------------------------------------------------------
# AWS Configuration
# ------------------------------------------------------------------------------
# AWS Region where your S3 buckets and services are located
# Common values: us-east-1, us-east-2, us-west-2, eu-west-1
DEFAULT_AWS_REGION=us-east-2

# Your AWS Account ID (12-digit number)
# Find it in AWS Console -> Account menu (top right)
AWS_ACCOUNT_ID=YOUR_AWS_ACCOUNT_ID_HERE

# ------------------------------------------------------------------------------
# AWS S3 Buckets
# ------------------------------------------------------------------------------
# S3 bucket for storing vector embeddings (AWS S3 Vectors service)
# Format: your-bucket-name-{account_id}
# Must be created in AWS Console before running the app
S3_VECTOR=lit-llm-s3-vectors-YOUR_ACCOUNT_ID

# S3 bucket for storing raw paper data (JSON files)
# Format: your-bucket-name
# Must be created in AWS Console before running the app
BEDROCK_KNOWLEDGE_S3_DATA=lit-review-papers

# S3 bucket for storing uploaded CSV files (Lambda-compatible storage)
# Format: your-bucket-name
# Must be created in AWS Console before running the app
# This bucket temporarily stores user-uploaded CSV files for processing
S3_DATA_CSV=lit-review-upload

# ------------------------------------------------------------------------------
# Optional: AWS Bedrock Knowledge Base (Future Use)
# ------------------------------------------------------------------------------
# Reserved for future Bedrock Knowledge Base integration
# Not currently used by the application
BEDROCK_KNOWLEDGE_BASE_ID=lit-review-kb-YOUR_ACCOUNT_ID

# ------------------------------------------------------------------------------
# Optional: CORS Configuration
# ------------------------------------------------------------------------------
# Comma-separated list of allowed origins for CORS
# Development: http://localhost:3000
# Production: https://your-frontend-domain.com,https://www.your-frontend-domain.com
# ALLOWED_ORIGINS=http://localhost:3000

# ------------------------------------------------------------------------------
# Optional: Environment Type
# ------------------------------------------------------------------------------
# Set to "production" to enable HTTPS-only cookies and other production features
# Values: development, production
# ENVIRONMENT=development

# ==============================================================================
# END OF CONFIGURATION
# ==============================================================================
